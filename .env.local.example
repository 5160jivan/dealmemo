# =============================================================
# DealMemo — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# -----------------------------------------------
# Milestone 1: Required for basic streaming chat
# -----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------
# Milestone 2: Web search tools
# -----------------------------------------------
# Option A: Tavily (recommended, designed for AI agents)
TAVILY_API_KEY=tvly-...

# Option B: Serper (Google search results)
SERPER_API_KEY=...

# -----------------------------------------------
# Milestone 4: Observability (Langfuse)
# -----------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASEURL=https://cloud.langfuse.com

# -----------------------------------------------
# Milestone 5: Rate limiting (Upstash Redis)
# -----------------------------------------------
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# -----------------------------------------------
# Milestone 5: Auth (Clerk)
# -----------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
